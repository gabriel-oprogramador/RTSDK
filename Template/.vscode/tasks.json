{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/Game.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/Game.sh"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ],
            "detail": "Running Makefile"
        }
    ]
}